# ─── 프론트엔드 환경변수 템플릿 ──────────────────────────────────
# 이 파일을 복사해 .env 를 만드세요:  cp .env.example .env
# (.env 는 gitignore 되어 커밋되지 않습니다)

# 백엔드 API 주소. 개발 중 프록시를 쓰면 빈 값으로 두세요(같은 출처 + Vite 프록시로 우회).
#   직접 호출하려면 실제 서버 주소(예: http://localhost:8000)를 넣으세요.
VITE_API_BASE_URL=

# true(기본): 목 데이터로 동작 / false: 실제 백엔드 호출
VITE_USE_MOCK=true

# true: 로그인(구글)만 목으로 우회하고 나머지 API는 실제 백엔드 호출.
#   백엔드 /auth/login/google 미구현 상태에서 화면 테스트용. 완성되면 false.
VITE_MOCK_LOGIN=false

# CORS 우회용 개발 프록시 대상. VITE_API_BASE_URL 을 빈 값으로 둘 때 여기로 프록시됩니다.
#   백엔드가 CORS 헤더를 주면 프록시 없이 VITE_API_BASE_URL 직접 호출도 가능.
VITE_API_PROXY_TARGET=http://localhost:8000

# 구글 로그인 Client ID (백엔드에서 발급받아 공유받은 공개값)
# VITE_GOOGLE_CLIENT_ID=
